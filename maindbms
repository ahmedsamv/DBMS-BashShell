# drop data base with confirm that command 
function drop_db() {
    read -p "Enter database name: " db

    if [ -z "$db" ]; then
        echo "Invalid name!"
        return
    fi

    if [ ! -d "$DB_ROOT/$db" ]; then
        echo "Database not found"
        return
    fi

    read -p "Are you sure you want to delete '$db'? (y/n): " confirm

    case $confirm in
        y|Y)
            rm -r "$DB_ROOT/$db"
            echo "Database deleted"
            ;;
        n|N)
            echo "Operation cancelled"
            ;;
        *)
            echo "Invalid choice"
            ;;
    esac
}
#-----------------------------------------

function rename_db() {
    read -p "Enter current database name: " old_name
        # Check if old DB exists
    if [ -z "$old_name" ] || [ ! -d "$DB_ROOT/$old_name" ]; then
        echo "Invalid input or Database '$old_name' not found!"
        return
    fi
    
    read -p "Enter new database name: " new_name
    
 # Check if new DB already exists
    if [ -z "$new_name" ] || [ -d "$DB_ROOT/$new_name" ]; then
        echo "Invalid input or Database '$new_name' already exists!"
        return
    fi
    
    # Validate input if empty
   

    # Rename
    mv "$DB_ROOT/$old_name" "$DB_ROOT/$new_name" \
        && echo "Database renamed successfully!" \
        || echo "Rename failed!"
}
