        echo "=================================="
    select choice in "Create DB" "List DB"  "Connect DB" "Drop DB" "Rename DB" "Exit"
    do
        case $choice in
            "Create DB") create_db ;; 
            "List DB") list_db ;; 
             "Drop DB") drop_db ;; 
             "Connect DB") connect_db ;; 
            "Rename DB") rename_db ;;
            "Exit") exit ;;
            *) echo "Invalid choice" ;;
        esac
    done
    done
}

