
 
 #! /usr/bin/bash
shopt -s extglob
 
 
function table_menu() {
    select choice in "list" "Back"
    do
        case $choice in
            "listing Table") list_tables ;;

            "Back") break ;;
        esac
    done
}
function list_tables() {

  if [ -z "$current_db" ]; then
    echo "Connect to database first"
    return
  fi

  echo "Tables:"
  ls "$current_db" | grep -v "_meta"
}
