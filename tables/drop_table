
function drop_table() {

  if [ -z "$dbname" ]; then
    echo "No database selected"
    return
  fi

  read -p "Enter table name: " table

  if [ ! -f "$table" ]; then
    echo "Table not found"
    return
  fi
   read -p "Are you sure you want to delete this table(y/n)" k
   
   
    case $k in
        y|Y)
            rm  "$table"
            echo "Database deleted"
            ;;
        n|N)
            echo "Operation cancelled"
            ;;
        *)
            echo "Invalid choice"
            ;;
    esac
   
   
   
   
 
}



  
