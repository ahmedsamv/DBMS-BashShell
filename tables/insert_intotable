




function insert_into_table() {

  if [ -z "$dbname" ]; then
    echo "No database selected"
    return
  fi

  read -p "Enter table name: " table

  if [ ! -f "$dbname/$table" ]; then
    echo "Table does not exist"
    return
  fi

  
  metadata=$(head -1 "$dbname/$table")

  IFS='|' read -ra columns <<< "$metadata"

  record=""
  col_index=0

  for col in "${columns[@]}"; do

    IFS=':' read col_name col_type col_pk col_nn <<< "$col"

    while true; do
      read -p "Enter value for $col_name ($col_type): " value

        
        
        
        
        
 
    if [ $col_index -eq 0 ]; then
      record="$value"
    else
      record="$record|$value"
    fi

    ((col_index++))
  done

  echo "$record" >> "$dbname/$table"
  echo "Record inserted successfully"
}
