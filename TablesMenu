#! /usr/bin/bash
shopt -s extglob
 source addFun 
 source tables/creatingtable
 source tables/listingtable
 source tables/drop_table
 source tables/insert_intotable 
function table_menu() {
  PS3="Your choice: "
echo "=================================="
 echo "select your choise:"
echo "=================================="
 
    select choice in "Create Table" "list Tables" "drop_Table" "insert_into_table" "Select_Table" "Delete_from_table" "update_table" "Back"
 
    do
        case $choice in
            "Create Table") create_table ;;
             "list Tables") list_tables ;;
             "drop_Table") drop_table  ;;
             "insert_into_table") insert_into_table ;;
             "Select_Table") select_table ;; 
             "Delete_from_table") delete_from_table ;;
 	     "update_table") update_table ;;
              "Back") break ;;
        esac
    done
}
 
