#! /usr/bin/bash
shopt -s extglob


function table_menu() {
    select choice in "Create Table" "Back"
    do
        case $choice in
            "Create Table") create_table ;;

            "Back") break ;;
        esac
    done
}

 
function create_table() {
  
  if [ -z "$dbname" ]; then
    echo "No database selected"
    return
  fi

  read -p "Enter table name: " table
  
 if [ -z "$table" ]; then
    echo "Table name cannot be empty"
    return
  fi


    
  if [[ ! "$table" =~ ^[a-zA-Z_][a-zA-Z0-9_]*$ ]]; then
    echo "Invalid table name (use letters, numbers, underscore only)"
    return
  fi

 
  if [ -f "$table" ]; then
    echo "Table already exists"
    return
  fi


  touch "$table"
 
   touch "${table}_meta"
 
  echo "Table created"
}
