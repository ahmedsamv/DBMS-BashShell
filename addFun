# ------------------------------------------ delete function ----------

function delete_from_table() {

    read -p "Enter table name: " table3
    table3=$(echo "$table3" | xargs)

    #  Validation
    if [[ -z "$table3" || -z "$current_db" ]]; then
        echo " Invalid input or no DB selected!"
        return
    fi

    if [[ ! -f "$current_db/$table3" ]]; then
        echo " Table does not exist!"
        return
    fi
while true; do
    header=$(head -1 "$current_db/$table3")
    IFS='|' read -ra cols <<< "$header"

    echo "Available columns:"
    for col_def in "${cols[@]}"; do
        col_name=$(echo "$col_def" | cut -d: -f1)
        echo "- $col_name"
    done

    read -p "Enter column name: " col_input
    col_input=$(echo "$col_input" | xargs)

    read -p "Enter value: " value
    value=$(echo "$value" | xargs)

    #  Find column index
    col_index=-1
    for i in "${!cols[@]}"; do
        name=$(echo "${cols[$i]}" | cut -d: -f1)
        if [[ "$name" == "$col_input" ]]; then
            col_index=$((i+1))
            break
        fi
    done

    if [[ $col_index -eq -1 ]]; then
        echo " Column not found!"
        continue
    fi

    #  Confirm delete
    read -p "Are you sure you want to delete rows where $col_input = $value? (y/n): " confirm
    [[ $confirm != [yY] ]] && echo "Cancelled" && return

    # Delete using awk (keep header)
    tmp_file=$(mktemp)

    awk -F'|' -v col="$col_index" -v val="$value" '
        NR==1 || $col != val
    ' "$current_db/$table3" > "$tmp_file"

    mv "$tmp_file" "$current_db/$table3"

    echo " Rows deleted successfully!"
          
    read -p "Do you want to select again? (y/n): " again2

        if [[ $again2 != [yY] ]]; then
            echo "Returning to menu..."
            break
        fi
    done
}

# ------------------------------------------ update function ----------
function update_table() {

    read -p "Enter table name: " tableu
    tableu=$(echo "$tableu" | xargs)

    #  Validation
    if [[ -z "$tableu" || -z "$current_db" ]]; then
        echo " Invalid input or no DB selected!"
        return
    fi

    if [[ ! -f "$current_db/$tableu" ]]; then
        echo " Table does not exist!"
        return
    fi

    file="$current_db/$tableu"
    
    while true; do
    header=$(head -1 "$file")
    
    IFS='|' read -ra cols <<< "$header"

    echo "Available columns:"
    for col_def in "${cols[@]}"; do
        echo "- $(echo "$col_def" | cut -d: -f1)"
    done

    #  Column to update
    read -p "Column to update: " col_update
    col_update=$(echo "$col_update" | xargs)

    #  Condition column
    read -p "Condition column: " cond_col
    cond_col=$(echo "$cond_col" | xargs)

    read -p "Condition value: " cond_val
    cond_val=$(echo "$cond_val" | xargs)

    read -p "New value: " new_val
    new_val=$(echo "$new_val" | xargs)

    #  Find indexes + metadata
    upd_index=-1
    cond_index=-1

    for i in "${!cols[@]}"; do
        name=$(echo "${cols[$i]}" | cut -d: -f1)

        [[ "$name" == "$col_update" ]] && upd_index=$((i+1))
        [[ "$name" == "$cond_col" ]] && cond_index=$((i+1))
    done

    if [[ $upd_index -eq -1 || $cond_index -eq -1 ]]; then
        echo " Column not found!"
        return
    fi

    #  Extract metadata for updated column
    col_meta="${cols[$((upd_index-1))]}"
    type=$(echo "$col_meta" | cut -d: -f2)
    pk=$(echo "$col_meta" | cut -d: -f3)
    nn=$(echo "$col_meta" | cut -d: -f4)

    # =============================
    # Constraints Validation
    # =============================

    # NOT NULL
    if [[ "$nn" == "NN" && -z "$new_val" ]]; then
        echo " This column cannot be NULL!"
        return
    fi

    # Data type
    case $type in
        int)
            [[ ! "$new_val" =~ ^-?[0-9]+$ ]] && echo " Must be integer!" && return
            ;;
        float)
            [[ ! "$new_val" =~ ^-?[0-9]+(\.[0-9]+)?$ ]] && echo "Must be float!" && return
            ;;
        string)
            ;; # always ok
    esac

    # PRIMARY KEY uniqueness
    if [[ "$pk" == "PK" ]]; then
        if awk -F'|' -v col="$upd_index" -v val="$new_val" 'NR>1 && $col==val {exit 1}' "$file"; then
            :
        else
            echo " Duplicate value for Primary Key!"
            return
        fi
    fi

    #  Confirm
    read -p "Confirm update? (y/n): " confirm
    [[ $confirm != [yY] ]] && echo "Cancelled" && return

    # =============================
    # Update using awk
    # =============================
    tmp_file=$(mktemp)

    awk -F'|' -v OFS='|' \
        -v ucol="$upd_index" -v ccol="$cond_index" \
        -v cond="$cond_val" -v new="$new_val" '
        NR==1 {print; next}
        {
            if ($ccol == cond) {
                $ucol = new
            }
            print
        }
    ' "$file" > "$tmp_file"

    mv "$tmp_file" "$file"

    echo " Update completed successfully!"
    read -p "Do you want to update another record? (y/n): " again

        if [[ $again != [yY] ]]; then
            echo "Returning to menu..."
            break
        fi
    done
}
