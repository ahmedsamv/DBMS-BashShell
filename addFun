#! /usr/bin/bash 

# ------------------------------------------ spesific_column function ----------
function spesific_column () {
 header=$(head -1 "$current_db/$tablex")
    IFS='|' read -ra cols <<< "$header"

    echo "Available columns:"
    for col_def in "${cols[@]}"; do
        col_name=$(echo "$col_def" | cut -d: -f1)
        echo "- $col_name"
    done

    read -p "Enter column name: " col_input
    col_input=$(echo "$col_input" | xargs)

    # find column index
    col_index=-1
    for i in "${!cols[@]}"; do
        name=$(echo "${cols[$i]}" | cut -d: -f1)
        if [[ "$name" == "$col_input" ]]; then
            col_index=$((i+1))
            break
        fi
    done

    if [[ $col_index -eq -1 ]]; then
        echo " Column not found!"
        return
    fi

    echo "Column: $col_input"

    # print column with header
    {
        echo "$col_input"
        tail -n +2 "$current_db/$tablex" | cut -d'|' -f"$col_index"
    } | column -t


}
# ------------------------------------------ Select_W_Condition function ----------
function Select_W_Condition () {

 header=$(head -1 "$current_db/$tablex")
    IFS='|' read -ra cols <<< "$header"

    echo "Available columns:"
    for col_def in "${cols[@]}"; do
        col_name=$(echo "$col_def" | cut -d: -f1)
        echo "- $col_name"
    done

    read -p "Enter column name: " col_input
    col_input=$(echo "$col_input" | xargs)

    read -p "Enter value: " value
    value=$(echo "$value" | xargs)

    # find column index
    col_index=-1
    for i in "${!cols[@]}"; do
        name=$(echo "${cols[$i]}" | cut -d: -f1)
        if [[ "$name" == "$col_input" ]]; then
            col_index=$((i+1))
            break
        fi
    done

    if [[ $col_index -eq -1 ]]; then
        echo "Column not found!"
        return
    fi

    echo "Result:"

    awk -F'|' -v col="$col_index" -v val="$value" '
        NR==1 || $col == val
    ' "$current_db/$tablex" | column -t -s "|"

}



	# ------------------------------------------ select function ----------
